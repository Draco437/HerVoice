{
  "expo": {
    "name": "HerVoice",
    "slug": "hervoice",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hervoice.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "HerVoice needs your location to detect where you are rating and show nearby safety data."
      }
    },
    "android": {
      "package": "com.hervoice.app",
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "plugins": [
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow HerVoice to use your location to submit safety reviews."
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "4925cdf6-540e-4a10-914a-330656444335"
      }
    }
  }
}
